JIRA_SITE=stage-redhat.atlassian.net
JIRA_PROJECTS=PROJ1,PROJ2
JIRA_POLL_INTERVAL=20

FIX_MODEL=claude-opus-4-6
FIX_SESSION_TTL=60

REVIEW_MODEL=claude-sonnet-4-6
REVIEW_SESSION_TTL=30

REVIEW_FIX_MODEL=claude-opus-4-6
REVIEW_FIX_SESSION_TTL=45
REVIEW_FIX_MAX_CYCLES=3

WATCHER_MODEL=claude-sonnet-4-6
WATCHER_SESSION_TTL=15

MAX_CONCURRENT_FIX_SESSIONS=3
MAX_CONCURRENT_REVIEW_SESSIONS=2
MAX_CONCURRENT_REVIEW_FIX_SESSIONS=2

# Ambient environment variables (set in ProjectSettings CR or per-session, not here):
# GITHUB_TOKEN — GitHub App token (preferred) or PAT
# JIRA_USERNAME — Atlassian email (fallback for label ops if MCP gaps)
# JIRA_API_TOKEN — Atlassian API token (fallback)
# SLACK_WEBHOOK_URL — Slack incoming webhook for notifications
# WATCHER_MODEL is used by the external cron that creates watcher sessions
