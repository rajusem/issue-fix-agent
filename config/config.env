JIRA_SITE=stage-redhat.atlassian.net
# JIRA_PROJECTS is not used by agent workflows — the watcher reads
# watched projects from config/projects.json instead.
# JIRA_PROJECTS=PROJ1,PROJ2
JIRA_POLL_INTERVAL=20

FIX_MODEL=claude-opus-4-6
FIX_SESSION_TTL=150

REVIEW_MODEL=claude-sonnet-4-6
REVIEW_SESSION_TTL=30

REVIEW_FIX_MODEL=claude-opus-4-6
REVIEW_FIX_SESSION_TTL=45
REVIEW_FIX_MAX_CYCLES=3

WATCHER_MODEL=claude-sonnet-4-6
WATCHER_SESSION_TTL=15

MAX_CONCURRENT_FIX_SESSIONS=4
MAX_CONCURRENT_REVIEW_SESSIONS=2
MAX_CONCURRENT_REVIEW_FIX_SESSIONS=2

# Runtime environment variables (set via K8s Secrets / OpenShell --env, not here):
# GITHUB_TOKEN — GitHub App token (preferred) or PAT (REQUIRED)
# JIRA_USERNAME — Atlassian email (REQUIRED — fallback for label ops if MCP is down)
# JIRA_API_TOKEN — Atlassian API token (REQUIRED — fallback for label ops if MCP is down)
# SLACK_WEBHOOK_URL — Slack incoming webhook for notifications
# WATCHER_MODEL is used by the external cron that creates watcher sessions

# Design Audit Loop
AUDIT_ENABLED=true
AUDIT_MAX_ITERATIONS=3
AUDIT_SKIP_SIMPLE=true
AUDIT_MODEL=claude-sonnet-4-6
# AUDIT_MAX_COST_USD is deferred — token-level cost tracking requires
# runtime API support not yet available. AUDIT_MAX_ITERATIONS is the
# effective cost control for now.

# Retry
MAX_FIX_RETRIES=2

# Shadow mode (dry-run for staged rollout)
# When true, agent PreToolUse hooks log but do not execute side effects
# (git push, gh pr create, Jira MCP calls). Watcher also skips Jira
# REST mutations. See docs/plan-opencode-openshell-migration.md rollout.
DRY_RUN=false

# RTK Token Optimization (optional, opt-in)
RTK_ENABLED=false